

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum PaymentFor {
  AUCTION
}

enum PaymentPhase {
  DEPOSIT
  BALANCE
}

model Payments {
  id String @id @default(uuid())
  userId String
  amount Int
  currency String @default("INR")
  status PaymentStatus
  for    PaymentFor
  referenceId String
  phase PaymentPhase @default(DEPOSIT)
  dueAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user User @relation(fields: [userId], references: [id])

  @@unique([referenceId, userId, phase])
}