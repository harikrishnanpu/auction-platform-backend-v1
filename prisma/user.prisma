model User {
  id                  String               @id @default(uuid())
  name                String
  email               String               @unique
  phone               String?              @unique
  password            String?
  address             String?
  avatar_url          String?
  authProvider        AuthProvider
  isVerified          Boolean              @default(false)
  status              UserStatus           @default(ACTIVE)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  kyc                 Kyc[]
  otps                Otp[]
  roles               UserRole[]
  auctions            Auction[]            @relation("SellerAuctions")
  wonAuctions         Auction[]            @relation("WonAuctions")
  bids                Bid[]
  auctionParticipants AuctionParticipant[]
  auctionCategories   AuctionCategory[]
  auctionChatMessages AuctionChatMessage[]
  wallet              Wallet?
  payments            Payments[]
  auctionWinners      AuctionWinner[]
}

model UserRole {
  id        String       @id @default(uuid())
  userId    String
  role      UserRoleType @default(USER)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id])
}

enum UserRoleType {
  USER
  SELLER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BLOCKED
}

enum AuthProvider {
  EMAIL
  GOOGLE
  GITHUB
  LOCAL
}
